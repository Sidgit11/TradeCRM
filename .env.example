# TradeCRM — Root environment file
# Copy this to .env and fill in your values.
# This file is used by the root docker-compose.yml.

# Database — matches the postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://tradecrm:tradecrm@postgres:5432/tradecrm

# Redis — matches the redis service in docker-compose.yml
REDIS_URL=redis://redis:6379/0

# Clerk Authentication (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# Email Provider — pick ONE: sendgrid | resend | ses | smtp | log
EMAIL_PROVIDER=log
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# Enrichment Pipeline (optional — needed for company enrichment)
# PERPLEXITY_API_KEY=
# FIRECRAWL_API_KEY=
# APOLLO_API_KEY=
# GEMINI_API_KEY=

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
