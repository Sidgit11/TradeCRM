# Database (Neon)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/neondb?ssl=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk Auth
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# AI Models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Enrichment Pipeline
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=
APOLLO_API_KEY=
GEMINI_API_KEY=

# WhatsApp (Gupshup) — Partner API
GUPSHUP_PARTNER_EMAIL=
GUPSHUP_PARTNER_SECRET=

# WhatsApp (Gupshup) — Direct API
GUPSHUP_HSM_USERID=
GUPSHUP_HSM_PASSWORD=
GUPSHUP_TWOWAY_USERID=
GUPSHUP_TWOWAY_PASSWORD=
GUPSHUP_WABA_NUMBER=
GUPSHUP_API_KEY=
GUPSHUP_APP_ID=
GUPSHUP_WEBHOOK_SECRET=
GUPSHUP_WEBHOOK_URL=

# Email Provider — pick ONE: sendgrid | resend | ses | smtp | log
# Set the provider name and fill in the matching credentials below.
# Default is 'log' which prints emails to console (for development).
EMAIL_PROVIDER=log

# Option 1: SendGrid (https://sendgrid.com)
SENDGRID_API_KEY=

# Option 2: Resend (https://resend.com) — recommended for getting started fast
RESEND_API_KEY=

# Option 3: Amazon SES (https://aws.amazon.com/ses/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1

# Option 4: Any SMTP server (Gmail, Outlook, Zoho, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Web Search (for Research Agent)
BRAVE_SEARCH_API_KEY=

# TradeGenie (Dify)
DIFY_API_KEY=
DIFY_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENCRYPTION_KEY=your-fernet-key-for-oauth-tokens
DEV_MODE=false
